# Al clonar el repositorio, copia este archivo como ".env" y rellena los valores.
# Este archivo se sube a control de versiones, así que NO pongas secretos reales.
# Al añadir nuevas variables, actualiza también el schema en "src/env.js".

# ==============================================================================
# Configuración de la aplicación
# ==============================================================================

# Entorno de ejecución — REQUERIDO (por defecto: "development")
NODE_ENV="development"

# ==============================================================================
# Base de datos
# ==============================================================================

# URL de conexión a PostgreSQL — REQUERIDO
DATABASE_URL="postgresql://postgres:password@localhost:5432/base"

# ==============================================================================
# Autenticación (better-auth)
# ==============================================================================

# Secreto para firmar tokens JWT — REQUERIDO en producción, opcional en desarrollo
# Genera uno con: openssl rand -hex 32
BETTER_AUTH_SECRET=""

# Inngest (opcional en desarrollo)
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
# URL base del servidor Inngest self-hosted (opcional, por defecto usa Inngest Cloud)
# INNGEST_BASE_URL="https://inngest.kaudit.dev"

# ==============================================================================
# GitHub App
# ==============================================================================

# Token personal de GitHub — REQUERIDO en producción, opcional en desarrollo
# Permite crear PRs y añadir comentarios a repositorios
# Crea uno en: https://github.com/settings/tokens/new
# Permisos requeridos: repo, write:pull_requests
GITHUB_TOKEN=""

# ID de la GitHub App — OPCIONAL (necesario para modo webhook con instalación)
# Crea la App en: https://github.com/settings/apps/new
GITHUB_APP_ID=""

# Clave privada de la GitHub App (PEM) — OPCIONAL (requerido si se usa GITHUB_APP_ID)
GITHUB_APP_PRIVATE_KEY=""

# Client ID de OAuth de la GitHub App — OPCIONAL
GITHUB_APP_CLIENT_ID=""

# Client Secret de OAuth de la GitHub App — OPCIONAL
GITHUB_APP_CLIENT_SECRET=""

# Secreto para verificar webhooks de GitHub — OPCIONAL
GITHUB_WEBHOOK_SECRET=""

# ==============================================================================
# Modelos de IA (OpenRouter / Requesty)
# ==============================================================================

# API key para Requesty — REQUERIDO
REQUESTY_API_KEY=""

# API key para OpenRouter — REQUERIDO
OPENROUTER_API_KEY=""

# ==============================================================================
# Jobs en segundo plano (Inngest)
# ==============================================================================

# Clave de eventos de Inngest — OPCIONAL (solo si se usa Inngest)
INNGEST_EVENT_KEY=""

# Clave de firma de Inngest — OPCIONAL (solo si se usa Inngest)
INNGEST_SIGNING_KEY=""

# ==============================================================================
# Seguimiento de errores (Sentry)
# ==============================================================================

# DSN de Sentry — OPCIONAL
# Déjalo vacío para deshabilitar el reporte de errores
SENTRY_DSN=""
